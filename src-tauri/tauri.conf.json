{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IO 設備通訊對照表",
  "version": "0.1.3",
  "identifier": "com.ching-tech.io-list",
  "build": {
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd app && npm run dev",
    "beforeBuildCommand": "cd app && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "IO 設備通訊對照表",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' blob: data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "IO List Project",
        "ext": ["json"]
      }
    ]
  }
}
